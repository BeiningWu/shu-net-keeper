{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SHU Net Keeper",
  "version": "0.1.0",
  "identifier": "com.shu-net-keeper",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SHU Net Keeper",
        "width": 920,
        "height": 660,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
